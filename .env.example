# Root convenience env (each service also has its own .env.example).
# Docker-compose sets service URLs internally; these are for running locally.

# ai-multi-agent orchestrator
REDIS_URL=redis://localhost:6379/0
SQLITE_PATH=orchestrator.db
AUTOMATION_SERVER_URL=http://localhost:8002

# web (Next.js) -> paste your Neon URL
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
AI_MULTI_AGENT_URL=http://localhost:8001
