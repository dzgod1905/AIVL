# Root all-in-one docker-compose.yml (single machine). Copy to .env and fill in.
# Generate each secret with:  openssl rand -hex 32

# Redis broker password (internal only; never published to a host port).
REDIS_PASSWORD=change-me-redis

# orchestrator-db (Postgres) password (internal only).
ORCH_DB_PASSWORD=change-me-postgres

# Bearer token the web must present to the orchestrator (web ORCH_API_TOKEN
# must match this).
ORCH_API_TOKEN=change-me-orch-token

# Bearer token the orchestrator presents to automation-server (both sides match).
AUTOMATION_API_TOKEN=change-me-automation-token

# Interface the published orchestrator API binds to.
#   127.0.0.1 (default) = localhost only, safe.
#   0.0.0.0             = all interfaces (LAN). Only with token + firewall/overlay.
API_BIND=127.0.0.1

# Optional: real LLM calls for ai_agent. Empty => dummy echo. Configure keys to
# call a real model; any key that errors is skipped, all failing => dummy (never
# breaks a run). Details + Groq/OpenRouter free-tier examples in
# ai-multi-agent/.env.example.
#
# Preferred: a POOL as a JSON array on ONE line. Each call picks a random start
# entry then falls through the rest (spread load / survive rate limits).
# provider "openai" also covers OpenAI-compatible endpoints via base_url.
AI_AGENT_KEYS=
