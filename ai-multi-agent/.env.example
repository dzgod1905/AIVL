# ai-multi-agent config. Two uses:
#   (A) docker-compose (ai-multi-agent/docker-compose.yml) reads the vars marked
#       [compose] below for ${...} substitution.
#   (B) running the API/workers directly on the host (no Docker) reads the vars
#       marked [local] below straight from the environment (config.py os.getenv).
# Generate each secret with:  openssl rand -hex 32

# ---- [compose] docker-compose substitution --------------------------------
REDIS_PASSWORD=change-me-redis
ORCH_DB_PASSWORD=change-me-postgres
# Where automation-server is reachable FROM this machine. Same machine dev:
#   http://localhost:8002 . Different machine: http://<automation-host>:8002
#   or a private overlay name, e.g. http://automation.tailnet:8002
AUTOMATION_SERVER_URL=http://localhost:8002
# Interface the published API binds to (127.0.0.1 = localhost only).
API_BIND=127.0.0.1

# ---- security tokens (used by BOTH compose and local) ---------------------
# Callers (web) must present ORCH_API_TOKEN to the orchestrator.
# The orchestrator presents AUTOMATION_API_TOKEN to automation-server.
# Empty => auth DISABLED (local dev only). Set both for any real deployment.
ORCH_API_TOKEN=
AUTOMATION_API_TOKEN=

# ---- [local] direct host run (Cách C) -------------------------------------
# Set CELERY_EAGER=1 to run agents in-process (no Redis, no separate workers).
CELERY_EAGER=0
# Broker for a local run. With a password: redis://:PASS@localhost:6379/0
REDIS_URL=redis://localhost:6379/0
# Orchestrator DB (SEPARATE from the web's Neon DB).
#   local Postgres: postgresql://user:pass@localhost:5432/orchestrator
#   dedicated Neon: postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/orchestrator?sslmode=require
#   leave empty to use the SQLite file below
ORCH_DATABASE_URL=
SQLITE_PATH=orchestrator.db

# ---- agent behavior knobs -------------------------------------------------
DEFAULT_SIMULATE_INCOMPLETE=1
DEFAULT_MAX_ATTEMPTS=5
REASK_DELAY_SEC=0.5
# Simulated work time (seconds/attempt) so nodes stay visibly busy in the DAG.
AI_AGENT_DELAY_SEC=10
EXCEL_READER_DELAY_SEC=10
# Max decoded size of an uploaded .xlsx (bytes). Default 10 MiB.
MAX_XLSX_BYTES=10485760

# ---- real LLM calls (optional) --------------------------------------------
# Configure keys to make ai_agent call a REAL model instead of the dummy echo.
# Empty => dummy. Any key that errors is skipped (logged); if all fail the run
# falls back to dummy, it does not break. Read by the API (eager) and the workers
# (broker), so set it wherever ai_agent actually runs. For real calls, raise the
# step Timeout in the builder above the model latency.
#
# Preferred: a POOL of keys as a JSON array on ONE line. Each call picks a random
# start entry then falls through the rest (spread load, survive rate limits).
# provider "openai" also covers OpenAI-compatible endpoints (Groq, OpenRouter)
# via base_url. base_url/model are optional (per-provider defaults fill them in).
#   AI_AGENT_KEYS=[{"provider":"groq-note-use-openai","api_key":"..."}]  # see below
# Example (Groq free tier + OpenRouter free + Anthropic), single line:
#   AI_AGENT_KEYS=[{"provider":"openai","api_key":"gsk_xxx","base_url":"https://api.groq.com/openai/v1","model":"llama-3.3-70b-versatile"},{"provider":"openai","api_key":"sk-or-xxx","base_url":"https://openrouter.ai/api/v1","model":"meta-llama/llama-3.3-70b-instruct:free"},{"provider":"anthropic","api_key":"sk-ant-xxx","model":"claude-sonnet-5"}]
AI_AGENT_KEYS=[
    {
        "provider": "openai",
        "api_key": "sk-proj-1234567890",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o"
    },
    {
        "provider": "anthropic",
        "api_key": "sk-proj-1234567890",
        "model": "claude-sonnet-5"
    }
]
#
# Backward-compatible single-key fallback (used only when AI_AGENT_KEYS is empty).
# Anthropic preferred when both set.
# ANTHROPIC_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_AGENT_MAX_TOKENS=1024
# AI_AGENT_HTTP_TIMEOUT=60
