# Neon Postgres (Drizzle). Paste your pooled connection string.
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Orchestrator base URL (server-side only). The web talks only to the
# orchestrator; automation-server is reached by the orchestrator, not the web.
AI_MULTI_AGENT_URL=http://localhost:8001

# Shared-secret bearer token for the orchestrator (must match ORCH_API_TOKEN on
# the ai-multi-agent side). Server-side only; never exposed to the browser.
# Leave empty for local dev with auth disabled. REQUIRED for any real deployment.
ORCH_API_TOKEN=
