# automation-server config. Copy to .env.
# Generate the token with:  openssl rand -hex 32
PORT=8002

# Interface the published port binds to (127.0.0.1 = localhost only).
# Set 0.0.0.0 to let the orchestrator machine reach it (with token + firewall).
AUTOMATION_BIND=127.0.0.1

# Bearer token callers (the orchestrator) must present. MUST match the
# orchestrator's AUTOMATION_API_TOKEN. Empty => auth DISABLED (dev only).
AUTOMATION_API_TOKEN=
